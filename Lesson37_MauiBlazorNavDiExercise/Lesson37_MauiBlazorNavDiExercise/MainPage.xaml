<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Lesson37_MauiBlazorNavDiExercise"
             xmlns:components="clr-namespace:Lesson37_MauiBlazorNavDiExercise.Components"
             x:Class="Lesson37_MauiBlazorNavDiExercise.MainPage">

    <VerticalStackLayout >

        <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>
    </VerticalStackLayout>

</ContentPage>

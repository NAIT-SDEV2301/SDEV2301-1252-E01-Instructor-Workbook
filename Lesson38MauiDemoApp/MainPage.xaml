<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Lesson38MauiDemoApp"
             xmlns:components="clr-namespace:Lesson38MauiDemoApp.Components"
             x:Class="Lesson38MauiDemoApp.MainPage">

    <!-- Auto means size based on the container -->
    <!-- * means Take all remaining available space-->
    <Grid RowDefinitions="Auto,*">
        <BlazorWebView x:Name="blazorWebView" HostPage="wwwroot/index.html">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>
    </Grid>
    

</ContentPage>
